{
  "name": "webdnn",
  "version": "2.0.0",
  "description": "WebDNN",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild:js": "node scripts/ensure-generated-stubs.mjs",
    "build:js": "node scripts/build.mjs",
    "build:dts": "tsc -p tsconfig.json --emitDeclarationOnly --noEmit false --outDir dist/types",
    "build": "npm run build:js && npm run build:dts",
    "build:all": "npm run makeShaderList && npm run build",
    "dev": "node scripts/build.mjs",
    "lint": "eslint src/descriptor_runner",
    "lint:fix": "eslint --fix src/descriptor_runner",
    "format": "prettier --write \"src/descriptor_runner/**/*.ts\"",
    "format:check": "prettier --check \"src/descriptor_runner/**/*.ts\"",
    "shader:wasm": "python3 src/shader/wasm/compile.py",
    "shader:webgpu": "node src/shader/webgpu/compile.js",
    "makeShaderList": "python3 scripts/make_operator_entries.py",
    "prepublishOnly": "npm run build",
    "server": "npx http-server -c-1",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "pretypecheck": "node scripts/ensure-generated-stubs.mjs",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git@github:mil-tokyo/webdnn.git"
  },
  "author": {
    "name": "Masatoshi Hidaka",
    "email": "hidaka@edgeintelligence.jp"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "onnx-proto": "^4.0.4",
    "pako": "^2.0.3"
  },
  "devDependencies": {
    "@types/pako": "^1.0.1",
    "@webgpu/glslang": "^0.0.15",
    "@webgpu/types": "^0.1.70",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "deep-neural-networks",
    "accelerate",
    "optimization",
    "javascript",
    "webgpu"
  ],
  "allowScripts": {
    "esbuild@0.21.5": true
  }
}
